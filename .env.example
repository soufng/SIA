# SIA — Variables d'environnement
#
# Copiez ce fichier en `.env` puis remplacez chaque valeur "REPLACE_ME"
# par une valeur réelle. Ne committez JAMAIS le `.env` final
# (il est dans `.gitignore`).
#
# Pour générer des secrets frais d'un coup :
#   python scripts/rotate_secrets.py

# ---- Mode d'exécution ----
# "development" : tous les défauts sont permis (debug, secrets bidon).
# "production"  : la configuration refuse de démarrer si un secret est
#                 le défaut, garantissant qu'aucune install par défaut
#                 ne se retrouve exposée.
SIA_ENV=development

# ---- MongoDB ----
MONGODB_URL=mongodb://127.0.0.1:27017/sia
MONGO_DB_NAME=sia

# ---- Qdrant ----
SIA_QDRANT_URL=http://localhost
SIA_QDRANT_PORT=6333

# ---- Modèle d'embedding ----
# Défaut : intfloat/multilingual-e5-base (768 dimensions).
SIA_EMBEDDING_MODEL=intfloat/multilingual-e5-base
SIA_EMBEDDING_VECTOR_SIZE=768

# ---- Pipeline plagiat ----
SIA_PLAGIARISM_SIMILARITY_THRESHOLD=0.60
SIA_PLAGIARISM_TOP_K=15

# ---- Limites d'upload ----
# Taille max du PDF accepté (Mo). 0 = pas de limite.
SIA_UPLOAD_MAX_MB=20

# ---- Advanced RAG (LLM) ----
# Provider supportés : auto, openai, anthropic, ollama, none.
SIA_ADVANCED_RAG_ENABLED=true
SIA_RAG_LLM_PROVIDER=ollama
SIA_RAG_LLM_MODEL=llama3.2:3b
SIA_RAG_LLM_BASE_URL=http://localhost:11434
SIA_RAG_LLM_API_KEY=
SIA_RAG_LLM_TIMEOUT_SECONDS=600
SIA_RAG_LLM_MAX_TOKENS=900
SIA_RAG_LLM_TEMPERATURE=0.2
SIA_RAG_MAX_PASSAGES=6

# ---- Authentification ----
SIA_AUTH_ENABLED=true
SIA_ADMIN_USERNAME=admin
# IMPORTANT : générer un hash réel avec :
#   python -m backend.core.auth "MON_MOT_DE_PASSE"
SIA_ADMIN_PASSWORD_HASH=REPLACE_ME
# IMPORTANT : générer un secret aléatoire de 64+ caractères avec :
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SIA_JWT_SECRET=REPLACE_ME
SIA_JWT_EXPIRY_MINUTES=480

# ---- 2FA TOTP ----
SIA_OTP_ENABLED=true
# IMPORTANT : générer un secret base32 frais avec :
#   python -m backend.core.totp generate
SIA_OTP_SECRET=REPLACE_ME
SIA_OTP_ISSUER=SIA-CCM
